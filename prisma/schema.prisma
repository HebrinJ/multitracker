// ============================================================================
// МУЛЬТИТРЕКЕР - Схема базы данных
// ============================================================================
// Этот файл описывает структуру всех таблиц в базе данных.
// Prisma использует его для создания клиента БД и миграций.
//
// После изменения этого файла выполните:
// npx prisma migrate dev --name описание_изменений
// npx prisma generate
// ============================================================================

// Генератор клиента Prisma
generator client {
  provider = "prisma-client-js"
}

// Источник данных - SQLite
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ПОЛЬЗОВАТЕЛИ
// ============================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nickname  String
  avatar    String?
  firstName String?
  lastName  String?
  role      String   @default("USER")  // USER, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books        BookEntry[]
  movies       MovieEntry[]
  reviews      Review[]
  addedBooks   Book[]
  addedMovies  Movie[]
  notifications Notification[]
}

// ============================================================================
// ЖАНРЫ
// ============================================================================

model Genre {
  id        String   @id @default(cuid())
  name      String
  type      String              // BOOK, MOVIE
  createdAt DateTime @default(now())

  books     BookGenre[]
  movies    MovieGenre[]

  @@unique([name, type])
}

model BookGenre {
  bookId    String
  book      Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  genreId   String
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([bookId, genreId])
}

model MovieGenre {
  movieId   String
  movie     Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  genreId   String
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([movieId, genreId])
}

// ============================================================================
// КНИГИ
// ============================================================================

model Book {
  id          String   @id @default(cuid())
  title       String
  author      String
  year        Int?
  description String?
  cover       String?
  addedById   String?
  addedBy     User?    @relation(fields: [addedById], references: [id])
  status      String   @default("PENDING")  // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     BookEntry[]
  reviews     Review[]
  genres      BookGenre[]

  @@unique([title, author])
}

model BookEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  status    String   @default("NOT_READ")  // NOT_READ, READING, COMPLETED, ON_HOLD, DROPPED
  rating    Int?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
}

// ============================================================================
// ФИЛЬМЫ
// ============================================================================

model Movie {
  id          String   @id @default(cuid())
  title       String
  director    String
  year        Int?
  description String?
  poster      String?
  addedById   String?
  addedBy     User?    @relation(fields: [addedById], references: [id])
  status      String   @default("PENDING")  // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     MovieEntry[]
  reviews     Review[]
  genres      MovieGenre[]

  @@unique([title, director])
}

model MovieEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  status    String   @default("NOT_WATCHED")  // NOT_WATCHED, WATCHING, COMPLETED, ON_HOLD, DROPPED
  rating    Int?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, movieId])
}

// ============================================================================
// ОТЗЫВЫ
// ============================================================================

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId    String?
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  movieId   String?
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  rating    Int
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// УВЕДОМЛЕНИЯ
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // CONTENT_APPROVED, CONTENT_REJECTED, CONTENT_MODIFIED
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}